{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Represents a potential customer lead generated by the AI assistant.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the dealership or user who owns this lead"
        },
        "name": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "vehicle_interest": {
          "type": "string"
        },
        "budget": {
          "type": "string"
        },
        "timeline": {
          "type": "string"
        },
        "payment_type": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "pipeline_stage": {
          "type": "string"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp in milliseconds"
        },
        "updatedAt": {
          "type": "number",
          "description": "Timestamp in milliseconds"
        }
      },
      "required": ["userId", "name", "phone", "pipeline_stage", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": {
        "$ref": "#/entities/Lead"
      },
      "description": "Stores all CRM leads."
    }
  }
}
